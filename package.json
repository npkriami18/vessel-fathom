{
    "name":  "vessel-fathom",
    "version":  "0.1.0",
    "description":  "Local-first interaction verification for live apps.",
    "type":  "module",
    "private":  true,
    "bin":  {
                "fathom":  "./bin/fathom.js"
            },
    "engines":  {
                    "node":  "\u003e=22"
                },
    "scripts":  {
                    "build":  "node scripts/build.js",
                    "lint":  "node scripts/lint.js",
                    "format:check":  "node scripts/format-check.js",
                    "typecheck":  "tsc --noEmit",
                    "test":  "node --test test/*.test.js",
                    "check":  "node scripts/build.js \u0026\u0026 node scripts/lint.js \u0026\u0026 node scripts/format-check.js \u0026\u0026 tsc --noEmit \u0026\u0026 node --test test/*.test.js"
                },
    "devDependencies":  {
                            "esbuild":  "^0.28.1",
                            "typescript":  "^5.5.4"
                        },
    "dependencies":  {
                         "express":  "^5.2.1"
                     }
}
