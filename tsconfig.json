{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "allowJs":  true,
                            "checkJs":  false,
                            "noEmit":  true,
                            "strict":  true,
                            "skipLibCheck":  true
                        },
    "include":  [
                    "src/**/*.js",
                    "bin/**/*.js",
                    "scripts/**/*.js",
                    "test/**/*.js"
                ]
}
